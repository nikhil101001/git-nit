{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["electron-vite/node", "node"]
  }
}
